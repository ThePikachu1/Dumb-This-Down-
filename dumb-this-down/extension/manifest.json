{
  "manifest_version": 3,
  "name": "Dumb This Down",
  "version": "6.7",
  "description": "Simplifies selected text to a 5th grade reading level using AWS Bedrock.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://*.execute-api.us-east-1.amazonaws.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
